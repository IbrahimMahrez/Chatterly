<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forget Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-info d-flex justify-content-center align-items-center" style="height: 100vh;">
    
    <div class="container bg-dark p-5 rounded text-white">
        <h1>Forget Password</h1>

        <!-- ✅ أهم تصليح هنا -->
        <form action="/password/forgot_password" method="POST" class="d-flex flex-column gap-3">  
            
            <label>Email:</label>
            <input type="email" name="email" class="form-control" required>

            <!-- ✅ زرار صحيح -->
            <button type="submit" class="btn btn-success">Submit</button>

        </form>
    </div>

</body>
</html>